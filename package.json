{
  "name": "niveshventures-platform",
  "version": "1.0.0",
  "description": "Niveshventures Crypto Platform Starter",
  "scripts": {
    "start:db": "docker-compose up -d",
    "stop:db": "docker-compose down",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:admin": "npm run dev --prefix admin-frontend",
    "install:all": "npm install --prefix backend && npm install --prefix frontend && npm install --prefix admin-frontend"
  }
}
